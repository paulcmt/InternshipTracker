// InternshipTracker - Internship Search Personal CRM
// Local-first, single user, SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- Enums ---

enum CompanyStatus {
  FIND_ENTRY_POINT
  PROCESS_IN_PROGRESS
  CLOSED
}

enum EntryPointType {
  JOB_POSTING
  RECRUITER
  ALUMNI
  REFERRAL
  COLD_APPLICATION
  EMPLOYEE
}

enum EntryPointStatus {
  TO_CONTACT
  CONTACTED
  RESPONDED
  WAITING
  FOLLOW_UP
  CLOSED
}

enum ApplicationType {
  REFERRAL
  DIRECT_CONTACT
  CAREERS_SITE
  COLD_APPLICATION
}

enum ApplicationStatus {
  PREPARATION
  SENT
  WAITING
  RESPONSE_RECEIVED
  HR_INTERVIEW
  TECHNICAL_INTERVIEW
  CASE_STUDY
  FINAL
  REJECTED
  OFFER
  WITHDRAWN
}

enum InterviewType {
  HR
  MANAGER
  TECHNICAL
  SYSTEM_DESIGN
  FIT
  FOUNDER
  CASE_STUDY
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  FEEDBACK_RECEIVED
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
}

// --- Models ---

model Company {
  id              String        @id @default(cuid())
  name            String
  sizeEstimate    String?       // e.g. "10-50", "50-200"
  country         String
  city            String?
  careersUrl      String?
  linkedinUrl     String?
  personalInterest Int          // 1-10
  status          CompanyStatus
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  entryPoints   EntryPoint[]
  applications  Application[]
  interviews    Interview[]
  actions       Action[]
}

model EntryPoint {
  id             String           @id @default(cuid())
  companyId      String
  type           EntryPointType
  personName     String?
  personRole     String?
  linkedinUrl    String?
  channel        String?          // e.g. LinkedIn, Email
  status         EntryPointStatus
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  actions      Action[]
}

model Application {
  id              String            @id @default(cuid())
  companyId       String
  entryPointId    String?
  roleTitle       String
  location        String?
  offerUrl        String?
  applicationType ApplicationType
  appliedAt       DateTime?
  status          ApplicationStatus
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entryPoint EntryPoint? @relation(fields: [entryPointId], references: [id], onDelete: SetNull)
  interviews Interview[]
  actions    Action[]
}

model Interview {
  id             String          @id @default(cuid())
  companyId      String
  applicationId  String
  interviewType  InterviewType
  interviewerName String?
  scheduledAt    DateTime?
  status         InterviewStatus
  feedback       String?
  strengths      String?
  improvements   String?
  nextStep       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actions     Action[]
}

model Action {
  id             String         @id @default(cuid())
  title          String
  description    String?
  status         ActionStatus
  priority       ActionPriority
  dueDate        DateTime?
  completedAt    DateTime?
  companyId      String?
  entryPointId   String?
  applicationId  String?
  interviewId    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  entryPoint   EntryPoint?   @relation(fields: [entryPointId], references: [id], onDelete: SetNull)
  application  Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  interview    Interview?    @relation(fields: [interviewId], references: [id], onDelete: SetNull)
}
