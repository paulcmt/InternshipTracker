{
  "name": "internship-tracker",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "hono": "^4.12.7",
    "@hono/node-server": "^1.19.10",
    "lodash": "^4.17.23"
  },
  "scripts": {
    "dev": "next dev -H localhost",
    "build": "next build",
    "start": "next start -H localhost",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:backup": "npx tsx scripts/backup-db.ts",
    "db:restore:latest": "npx tsx scripts/restore-db.ts",
    "db:migrate:backup": "npx tsx scripts/migrate-backup-db.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:safe": "npm run db:backup && prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:safe": "npm run db:backup && prisma db seed",
    "db:reset": "prisma migrate reset --force && prisma db seed",
    "db:reset:safe": "npm run db:backup && prisma migrate reset --force && prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^4.0.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
